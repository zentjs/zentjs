{
  "name": "@zentjs/zentjs",
  "version": "0.0.1",
  "description": "Framework web minimalista e performático para Node.js",
  "license": "BSD-3-Clause",
  "author": "Walber Vaz",
  "type": "module",
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walber-vaz/zentjs.git"
  },
  "bugs": {
    "url": "https://github.com/walber-vaz/zentjs/issues"
  },
  "homepage": "https://github.com/walber-vaz/zentjs#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zentjs",
    "framework",
    "http",
    "api",
    "nodejs",
    "esm"
  ],
  "scripts": {
    "build": "npm run lint && npm run test && npm pack --dry-run",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "bench": "node bench/run-benchmarks.mjs",
    "bench:save-baseline": "node bench/run-benchmarks.mjs --save-baseline",
    "bench:frameworks": "node bench/frameworks-bench.mjs",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "express": "^5.2.1",
    "fastify": "^5.7.4",
    "globals": "17.4.0",
    "jiti": "^2.6.1",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "vitest": "4.0.18"
  }
}